// Trimly data model. See docs/data-model.md for the rationale behind each
// modeling decision (Barber decoupled from User, per-barber Services, UTC
// storage, notifyToken vs booking.id, etc.).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  // BARBER — reserved for the future: extra masters with their own login,
  // each seeing and managing only their own bookings/services/schedule.
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  // Nullable: a self-registered account exists (unverified) before its owner
  // sets a password via the email-confirmation link. See docs/data-model.md.
  passwordHash String?
  role         Role     @default(ADMIN)
  // Set when the confirmation link is used; null means the email is unverified
  // and the account cannot log in (and has no Barber profile yet).
  emailVerifiedAt    DateTime?
  barber             Barber?
  verificationTokens EmailVerificationToken[]
  createdAt          DateTime @default(now())
}

// Single-use, time-boxed token backing the barber self-registration email link.
// Only the sha256 hash is stored — the raw token lives solely in the emailed URL,
// so a DB leak can't be turned into a working link. See docs/decisions-log.md.
model EmailVerificationToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model Barber {
  id           String         @id @default(cuid())
  // The owner logs in as ADMIN and *is* this barber — one account, one profile.
  // Optional so barber data survives if the user account is deleted (SetNull),
  // and to leave room for future BARBER-role masters without their own login.
  user         User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId       String?        @unique
  displayName  String
  bio          String?
  photoUrl     String?
  timezone     String         @default("Europe/Brussels")
  isActive     Boolean        @default(true)
  services     Service[]
  workingHours WorkingHours[]
  dayOffs      DayOff[]
  bookings     Booking[]
  createdAt    DateTime       @default(now())
}

model Service {
  id              String    @id @default(cuid())
  barber          Barber    @relation(fields: [barberId], references: [id], onDelete: Cascade)
  barberId        String
  name            String
  durationMinutes Int
  price           Decimal   @db.Decimal(10, 2)
  isActive        Boolean   @default(true)
  bookings        Booking[]

  @@index([barberId])
}

model WorkingHours {
  id        String @id @default(cuid())
  barber    Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)
  barberId  String
  weekday   Int // 0-6, 0 = Sunday
  startTime String // "09:00"
  endTime   String // "18:00"

  @@index([barberId])
}

model DayOff {
  id       String   @id @default(cuid())
  barber   Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  barberId String
  date     DateTime @db.Date
  reason   String?

  @@index([barberId])
}

model Booking {
  id             String        @id @default(cuid())
  barber         Barber        @relation(fields: [barberId], references: [id])
  barberId       String
  service        Service       @relation(fields: [serviceId], references: [id])
  serviceId      String
  clientName     String
  clientPhone    String
  startAt        DateTime
  endAt          DateTime
  status         BookingStatus @default(CONFIRMED)
  notifyToken    String        @unique @default(cuid())
  telegramChatId String?
  createdAt      DateTime      @default(now())

  @@index([barberId, startAt])
}
