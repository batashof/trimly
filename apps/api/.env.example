# PostgreSQL connection string from Neon (https://neon.tech).
# Use the *pooled* connection string for the app at runtime.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.eu-central-1.aws.neon.tech/trimly?sslmode=require"

# Direct (non-pooled) connection, used by Prisma Migrate. On Neon this is the
# same host without the "-pooler" segment. Falls back to DATABASE_URL if unset.
DIRECT_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/trimly?sslmode=require"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# First admin user, created by `pnpm --filter @trimly/api db:seed`.
ADMIN_EMAIL="admin@trimly.app"
ADMIN_PASSWORD="change-me-min-8-chars"

# Telegram bot (see docs/notifications-telegram.md). Leave blank until the bot
# is created via @BotFather — the notification flow is added in roadmap step 4.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""
TELEGRAM_BOT_USERNAME="TrimlyBot"

# Server
PORT="3001"
